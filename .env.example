# ==================================================
# IT Helpdesk Agent - 环境变量配置
# ==================================================
# 复制此文件为 .env 并填入你的真实密钥
# cp .env.example .env

# --- LLM API 配置 ---
# 使用 OpenAI（二选一）
OPENAI_API_KEY=sk-your-openai-api-key-here

# 使用 Anthropic（二选一）
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# --- LLM 模型选择 ---
ROUTER_MODEL=gpt-4o-mini
ANSWER_MODEL=gpt-4o

# --- LangSmith 可观测性（可选但强烈推荐） ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-langsmith-api-key-here
LANGCHAIN_PROJECT=it-helpdesk

# --- 向量数据库 ---
CHROMA_PERSIST_DIR=./chroma_db

# --- LangGraph checkpoint（可选）---
# 留空：仅内存，进程结束丢失。设为 sqlite 文件路径可持久化，并支持 /threads/... 时间旅行 API
# LANGGRAPH_CHECKPOINT_SQLITE=./checkpoints/langgraph.db

# --- 服务配置 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
